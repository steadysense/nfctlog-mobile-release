<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.NFC" /> <!-- TODO: Integration: NFC permission -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Use this if we want to restrict the Google PlayStore to NFC supported devices. -->
    <!-- <uses-feature android:name="android.hardware.nfc" android:required="true" /> -->

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- TODO: Integration: Configure the launchMode for your NFC foreground dispatch activity. launchMode="singleTask" is not strictly required, but it should simplify the NFC integration. -->
        <activity android:name="at.steadysense.nfctlogdemo.MainActivity"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:exported="true"
            >

            <!-- In our case, the NFC foreground dispatch activity is also the launcher activity -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- TODO: Integration: Filter for the right NFC intent -->
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:scheme="https"
                    android:host="t.steadytemp.info" />
            </intent-filter>

        </activity>
        <!-- End of Integration -->

    </application>

</manifest>